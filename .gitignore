# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude
CLAUDE.md
AGENTS.md

# Release artifacts — hosted on Cloudflare R2 (dl.tech-m8.solutions), not git/Pages.
# Hand-written install.sh / install.ps1 stay tracked.
public/downloads/**/*.apk
public/downloads/**/*.zip
public/downloads/**/*.tar.gz
public/downloads/**/*.dmg
public/downloads/**/*.exe
public/downloads/**/*.sha256
public/downloads/**/*_checksums.txt
public/downloads/job-hunter/VERSION
